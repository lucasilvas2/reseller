APP_NAME=Dealer
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
# Para desenvolvimento, use SQLite para simplicidade
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite
# Para produção/MySQL, descomente as linhas abaixo:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=dealer
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue Configuration
# Para desenvolvimento com LocalStack: sqs
# Para desenvolvimento simples: database
# Para produção: sqs
QUEUE_CONNECTION=sqs

# Cache Configuration
# Para desenvolvimento: database
# Para alta performance: redis
CACHE_STORE=database
CACHE_PREFIX=

# Redis Configuration (necessário se CACHE_DRIVER=redis)
MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6380

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS/SQS Configuration
# Para desenvolvimento com LocalStack
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=meu-bucket
AWS_ENDPOINT=http://localhost:4566
AWS_USE_PATH_STYLE_ENDPOINT=true

# Para produção AWS real, configure:
# AWS_ACCESS_KEY_ID=your_real_access_key
# AWS_SECRET_ACCESS_KEY=your_real_secret_key
# AWS_ENDPOINT=  # Deixe vazio para usar AWS real
# AWS_USE_PATH_STYLE_ENDPOINT=false

# SQS Configuration
# LocalStack SQS prefix (desenvolvimento)
SQS_PREFIX=http://localhost:4566/000000000000
SQS_QUEUE=sales-default
SQS_SUFFIX=
# Configurações otimizadas para SQS
SQS_VISIBILITY_TIMEOUT=300
SQS_WAIT_TIME=20
SQS_MESSAGE_RETENTION=1209600
SQS_RECEIVE_WAIT_TIME=20

# Para produção AWS real:
# SQS_PREFIX=https://sqs.us-east-1.amazonaws.com/your-account-id

# Sales Queue Configuration
QUEUE_SALES_HIGH_PRIORITY=sales-high-priority
QUEUE_SALES_RETRY=sales-retry
QUEUE_SALES_RECOVERY=sales-recovery

# Sales Processing Configuration
SALES_PROCESSING_TIMEOUT=300
SALES_ORPHANED_MINUTES=10
SALES_RECOVERY_DELAY=5
SALES_MAX_ATTEMPTS=3
SALES_BACKOFF_SECONDS=30

# High Demand Configuration
# Para ativar otimizações de alta demanda (1000+ vendas/minuto):
# - Altere SALES_BATCH_PROCESSING=true
# - Altere SALES_CIRCUIT_BREAKER=true
# - Altere SALES_CACHE_ENABLED=true
# - Configure CACHE_DRIVER=redis
# - Reduza SALES_LOCK_TIMEOUT para 3-5 segundos
SALES_LOCK_TIMEOUT=10
SALES_BATCH_PROCESSING=false
SALES_CIRCUIT_BREAKER=false
SALES_FAILURE_THRESHOLD=5
SALES_RECOVERY_TIME=300
SALES_CACHE_ENABLED=false
SALES_CACHE_TTL=30

VITE_APP_NAME="${APP_NAME}"
